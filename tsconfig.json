{
  "extends": "@mr-hope/tsconfig/bundler.json",
  "compilerOptions": {
    "allowJs": true,
    "target": "ES2017",
    "module": "node16",
    "moduleResolution": "node16",
    "moduleSuffixes": ["", ".wx", ".we", ".app"],
    "noEmit": true,
    "types": ["miniprogram-api-typings"]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.wxs",
    "scripts/**/*.ts",
    "typings/**/*.ts",
    "commitlint.config.ts",
    "eslint.config.js",
    "gulpfile.cjs"
  ]
}
