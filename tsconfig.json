{
  "extends": "@mr-hope/tsconfig/bundler.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "ES2017",
    "moduleSuffixes": ["", ".wx", ".we", ".app"],
    "noEmit": true,
    "types": ["miniprogram-api-typings"]
  },
  "include": ["app/**/*.ts", "scripts/**/*.ts", "typings/**/*.ts", "*.config.ts"]
}
