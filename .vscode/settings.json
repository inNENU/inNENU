{
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "oxc.unusedDisableDirectives": "deny",
  "cSpell.words": [
    "benbu",
    "canonicalize",
    "damnu",
    "danmu",
    "darkmode",
    "elif",
    "errcode",
    "errmsg",
    "gulpfile",
    "inited",
    "innenu",
    "jfif",
    "jingyue",
    "meilisearch",
    "miniapp",
    "miniprogram",
    "mptool",
    "nenu",
    "qqcode",
    "qqid",
    "qrcode",
    "qzone",
    "rmvb",
    "stylelint",
    "wechat",
    "weixin",
    "werun",
    "weui",
    "wxid",
    "wxml",
    "wxss"
  ],
  "git.ignoreLimitWarning": true,
  "minapp-vscode.cssExtname": "scss",
  "minapp-vscode.jsExtname": "ts",
  "minapp-vscode.wxmlFormatter": "prettier",
  "search.exclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.temp/**": true
  },
  "stylelint.snippet": ["css", "scss"],
  "stylelint.validate": ["css", "scss"]
}
