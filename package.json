{
  "name": "innenu",
  "version": "0.0.241227",
  "private": true,
  "homepage": "https://innenu.com",
  "bugs": {
    "url": "https://github.com/inNENU/inNENU/issues"
  },
  "license": "Mr.Hope LICENSE",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inNENU/inNENU.git"
  },
  "type": "module",
  "scripts": {
    "build:app": "gulp -f gulpfile.cjs buildApp",
    "build:we": "gulp -f gulpfile.cjs buildWeNENU",
    "build:wx": "gulp -f gulpfile.cjs buildWechat",
    "bundle:app": "gulp -f gulpfile.cjs bundleApp && tsx scripts/bundle.ts",
    "bundle:we": "gulp -f gulpfile.cjs bundleWeNENU && tsx scripts/bundle.ts",
    "bundle:wx": "gulp -f gulpfile.cjs bundleWechat && tsx scripts/bundle.ts",
    "changelog": "standard-version --skip.bump --skip.commit --skip.tag",
    "clean": "tsx scripts/del.js",
    "debug:wx": "gulp -f gulpfile.cjs debugWechat && tsx scripts/bundle.ts",
    "dev:app": "gulp -f gulpfile.cjs watchApp",
    "dev:we": "gulp -f gulpfile.cjs watchWeNENU",
    "dev:wx": "gulp -f gulpfile.cjs watchWechat",
    "lint": "pnpm lint:oxlint && oxfmt && pnpm lint:wxs --write && pnpm lint:wxml --write && pnpm lint:stylelint --fix",
    "lint:oxlint": "oxlint --deny-warnings --report-unused-disable-directives",
    "lint:stylelint": "stylelint **/*.scss",
    "lint:wxml": "prettier --check --parser html **/*.wxml",
    "lint:wxs": "prettier --check --parser babel-flow **/*.wxs",
    "prepare": "husky"
  },
  "dependencies": {
    "@mptool/all": "0.13.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@mr-hope/tsconfig": "0.0.3",
    "del": "8.0.1",
    "gulp": "5.0.1",
    "gulp-rename": "2.1.0",
    "gulp-replace": "1.1.4",
    "gulp-sourcemaps": "3.0.0",
    "gulp-typescript": "6.0.0-alpha.1",
    "gulp5-sass-plugin": "2.1.0",
    "husky": "9.1.7",
    "innenu-generator": "0.8.2",
    "miniprogram-api-typings": "5.1.2",
    "nano-staged": "1.0.2",
    "oxc-config-hope": "0.2.2",
    "oxfmt": "0.45.0",
    "oxlint": "1.60.0",
    "oxlint-tsgolint": "0.21.0",
    "postcss": "8.5.10",
    "rollup": "4.60.1",
    "rollup-plugin-esbuild": "6.2.1",
    "standard-version": "9.5.0",
    "stylelint": "17.8.0",
    "stylelint-config-hope": "11.0.0",
    "typescript": "6.0.2",
    "unrun": "0.2.35"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --deny-warnings --report-unused-disable-directives",
    "*.scss": "stylelint --fix",
    "*.wxml": "prettier --parser html --write",
    "*.wxs": "prettier --parser babel-flow --write"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "prettier": {
    "overrides": [
      {
        "files": "**/*.wxml",
        "options": {
          "parser": "html"
        }
      },
      {
        "files": "**/*.wxs",
        "options": {
          "parser": "babel-flow"
        }
      }
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
