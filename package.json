{
  "name": "innenu",
  "version": "0.0.260714",
  "private": true,
  "homepage": "https://innenu.com",
  "bugs": {
    "url": "https://github.com/inNENU/inNENU/issues"
  },
  "license": "Mr.Hope LICENSE",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inNENU/inNENU.git"
  },
  "type": "module",
  "scripts": {
    "build:app": "gulp -f gulpfile.cjs buildApp",
    "build:we": "gulp -f gulpfile.cjs buildWeNENU",
    "build:wx": "gulp -f gulpfile.cjs buildWechat",
    "bundle:app": "gulp -f gulpfile.cjs bundleApp && unrun scripts/bundle.ts",
    "bundle:we": "gulp -f gulpfile.cjs bundleWeNENU && unrun scripts/bundle.ts",
    "bundle:wx": "gulp -f gulpfile.cjs bundleWechat && unrun scripts/bundle.ts",
    "changelog": "conventional-changelog -p conventionalcommits",
    "clean": "unrun ./scripts/del.ts",
    "debug:wx": "gulp -f gulpfile.cjs debugWechat && unrun scripts/bundle.ts",
    "dev:app": "gulp -f gulpfile.cjs watchApp",
    "dev:we": "gulp -f gulpfile.cjs watchWeNENU",
    "dev:wx": "gulp -f gulpfile.cjs watchWechat",
    "lint": "pnpm lint:oxlint --fix && oxfmt && pnpm lint:wxs --write && pnpm lint:wxml --write && pnpm lint:stylelint --fix",
    "lint:oxlint": "oxlint --deny-warnings --report-unused-disable-directives",
    "lint:stylelint": "stylelint **/*.scss",
    "lint:wxml": "prettier --check --parser html **/*.wxml",
    "lint:wxs": "prettier --check --parser babel-flow **/*.wxs",
    "prepare": "husky"
  },
  "dependencies": {
    "@mptool/all": "0.14.0"
  },
  "devDependencies": {
    "@mr-hope/tsconfig": "0.0.4",
    "@types/node": "^22.20.1",
    "conventional-changelog": "8.0.1",
    "conventional-changelog-conventionalcommits": "10.2.1",
    "del": "8.0.1",
    "gulp": "5.0.1",
    "gulp-rename": "2.1.0",
    "gulp-replace": "1.1.4",
    "gulp-sourcemaps": "3.0.0",
    "gulp-typescript": "6.0.0-alpha.1",
    "gulp5-sass-plugin": "2.1.0",
    "husky": "9.1.7",
    "innenu-generator": "0.8.2",
    "miniprogram-api-typings": "5.2.1",
    "nano-staged": "1.0.2",
    "oxc-config-hope": "0.3.9",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "picocolors": "1.1.1",
    "postcss": "8.5.18",
    "prettier": "3.9.5",
    "stylelint": "17.14.0",
    "stylelint-config-hope": "11.0.0",
    "tsdown": "0.22.5",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "unrun": "0.3.1"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --deny-warnings --report-unused-disable-directives",
    "*.scss": "stylelint --fix",
    "*.wxml": "prettier --parser html --write",
    "*.wxs": "prettier --parser babel-flow --write"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "prettier": {
    "overrides": [
      {
        "files": "**/*.wxml",
        "options": {
          "parser": "html"
        }
      },
      {
        "files": "**/*.wxs",
        "options": {
          "parser": "babel-flow"
        }
      }
    ]
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.11.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "^24.18.0",
      "onFail": "error"
    }
  }
}
